#include <LiquidCrystal.h>
#include <EEPROM.h>

LiquidCrystal lcd(2, 3, 4, 5, 6, 7);
char card[13]; // 12 characters + 1 for null terminator

int attn1;
int attn2;
int attn3;
int attn4;

void setup() 
{ 
  lcd.begin(16, 2); 
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Classroom Attendance");
  lcd.setCursor(0, 1);
  lcd.print(" Swap your Card ");
  delay(1000);

  Serial.begin(9600);
  Serial.println("Hello!!");
  pinMode(13, OUTPUT);
  digitalWrite(13, HIGH);
  delay(1000);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Pratik Bhat..jee:");
  lcd.setCursor(0, 1);
  lcd.print(EEPROM.read(1));
  delay(3000);
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Diptanu Chak..ty:");
  lcd.setCursor(0, 1);
  lcd.print(EEPROM.read(2));
  delay(3000);
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Indrani Paul:");
  lcd.setCursor(0, 1);
  lcd.print(EEPROM.read(3));
  delay(3000);
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Ruparna Deb:");
  lcd.setCursor(0, 1);
  lcd.print(EEPROM.read(4));
  delay(3000);
  
  Serial.print("Attendance of Pratik Bhattacjee(216304021): ");
  Serial.println(EEPROM.read(1)); 
 
  Serial.print("Attendance of Diptanu Chakraborty(216304017): ");
  Serial.println(EEPROM.read(2)); 
  
  Serial.print("Attendance of Indrani Paul(216304005): ");
  Serial.println(EEPROM.read(3)); 
 
  Serial.print("Attendance of Ruparna Deb(2063040007): ");
  Serial.println(EEPROM.read(4));
}

char rx(void)
{
  while (!Serial.available());
  return Serial.read();
}

void loop()
{
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("AttendancePlease");
  lcd.setCursor(0, 1);
  lcd.print(" Swap your Card ");

  for (int i = 0; i < 12; i++)
  {
    card[i] = rx();
  }
  card[12] = '\0'; // Null-terminate for safety

  lcd.setCursor(0, 1);
  lcd.print("C#:");

  for (int i = 0; i < 12; i++)
  {
    lcd.setCursor(i + 4, 1);
    lcd.print(card[i]);
  }
  delay(1000);

  if (card[10] == '2' && card[11] == 'F')
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome Pratik");
    lcd.setCursor(0, 1);
    lcd.print("216304021");
    attn1 = EEPROM.read(1) + 1;
    EEPROM.write(1, attn1);
    delay(3000);
  }

  if (card[10] == 'B' && card[11] == 'D')
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome Diptanu  ");
    lcd.setCursor(0, 1);
    lcd.print("216304017");
    attn2 = EEPROM.read(2) + 1;
    EEPROM.write(2, attn2);
    delay(3000);
  }

  if (card[10] == 'E' && card[11] == '6')
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome Indrani ");
    lcd.setCursor(0, 1);
    lcd.print("216304005");
    attn3 = EEPROM.read(3) + 1;
    EEPROM.write(3, attn3);
    delay(3000);
  }

  if (card[10] == 'D' && card[11] == '2')
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome Ruparna");
    lcd.setCursor(0, 1);
    lcd.print("2063040007");
    attn4 = EEPROM.read(4) + 1;
    EEPROM.write(4, attn4);
    delay(3000);
  }

  if (card[10] == 'A' && card[11] == '4')
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Memory Cleared!");
    lcd.setCursor(0, 1);
    lcd.print("DEVICE READY");
    EEPROM.write(1, 0);
    EEPROM.write(2, 0);
    EEPROM.write(3, 0);
    EEPROM.write(4, 0);
    delay(3000);
  }
}
